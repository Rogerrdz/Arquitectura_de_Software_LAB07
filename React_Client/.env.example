# Backend API Base URL (puerto 8081 configurado en el backend)
VITE_API_BASE_URL=http://localhost:8081/api

# Real-time backends
# STOMP (Spring Boot) - usually same host as REST API, without /api suffix
VITE_STOMP_BASE=http://localhost:8081

# Usar mock (true) o API real (false)
# 
# DEVELOPMENT MODE (sin backend corriendo):
# VITE_USE_MOCK=true
#
# PRODUCTION MODE (con backend + PostgreSQL + JWT real):
# VITE_USE_MOCK=false
#
# Para la entrega del laboratorio: usar false (JWT real)
VITE_USE_MOCK=false
